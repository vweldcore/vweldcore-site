<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>VWELDCORE | Automation Infrastructure</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#050505;
color:#ffffff;
line-height:1.7;
}

.container{
width:92%;
max-width:1180px;
margin:auto;
padding:80px 0;
}

.hero{
padding-top:120px;
padding-bottom:100px;
text-align:left;
}

.hero h1{
font-size:64px;
line-height:1.1;
max-width:900px;
color:#00ff99;
margin-bottom:30px;
}

.hero p{
font-size:22px;
color:#aaaaaa;
max-width:850px;
margin-bottom:40px;
}

.cta-row{
display:flex;
flex-wrap:wrap;
gap:20px;
margin-top:30px;
}

.cta-btn{
display:inline-block;
padding:18px 34px;
background:#00ff99;
color:#000000;
font-weight:bold;
text-decoration:none;
border-radius:10px;
font-size:18px;
}

.secondary-btn{
background:#151515;
color:#ffffff;
border:1px solid #333333;
}

.stats{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
margin-top:70px;
}

.stat-box{
background:#101010;
padding:35px;
border-radius:16px;
border:1px solid #1f1f1f;
}

.stat-box h2{
font-size:48px;
color:#00ff99;
margin-bottom:10px;
}

.stat-box p{
color:#999999;
}

.section-title{
font-size:52px;
margin-bottom:20px;
}

.section-sub{
font-size:20px;
color:#999999;
max-width:900px;
margin-bottom:60px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:28px;
}

.card{
background:#0f0f0f;
padding:35px;
border-radius:18px;
border:1px solid #1f1f1f;
}

.card h3{
font-size:32px;
margin-bottom:20px;
}

.price{
font-size:58px;
font-weight:bold;
color:#00ff99;
margin-bottom:20px;
}

.card ul{
padding-left:20px;
}

.card li{
margin-bottom:14px;
color:#bbbbbb;
}

.proof-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
gap:25px;
}

.proof-box{
background:#101010;
padding:30px;
border-radius:16px;
border:1px solid #1f1f1f;
}

.proof-box h4{
font-size:28px;
margin-bottom:18px;
color:#00ff99;
}

.proof-box p{
color:#bbbbbb;
}

.contact-box{
background:#0f0f0f;
padding:45px;
border-radius:18px;
border:1px solid #1f1f1f;
}

.contact-box h2{
font-size:46px;
margin-bottom:20px;
}

.contact-box p{
font-size:20px;
color:#aaaaaa;
margin-bottom:30px;
}

.contact-item{
margin-bottom:18px;
font-size:20px;
}

.contact-item a{
color:#00ff99;
text-decoration:none;
}

.notice{
background:#0d0d0d;
padding:40px;
border-radius:18px;
border:1px solid #222222;
}

.notice h2{
font-size:40px;
margin-bottom:20px;
}

.notice p{
color:#999999;
margin-bottom:20px;
}

footer{
padding:50px 0;
text-align:center;
color:#666666;
font-size:15px;
border-top:1px solid #151515;
margin-top:60px;
}

@media(max-width:768px){

.hero h1{
font-size:42px;
}

.hero p{
font-size:18px;
}

.section-title{
font-size:38px;
}

.price{
font-size:42px;
}

}

</style>

</head>


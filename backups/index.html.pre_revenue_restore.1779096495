<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>VWELDCORE SYSTEMS</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#000;
color:#fff;
line-height:1.7;
}

.container{
width:90%;
max-width:1100px;
margin:auto;
padding:40px 0;
}

.hero{
padding:70px 0 40px;
}

.hero h1{
font-size:48px;
color:#00ff99;
margin-bottom:15px;
}

.hero p{
max-width:850px;
color:#bbb;
font-size:18px;
}

.telegram-btn{
display:inline-block;
margin-top:25px;
padding:14px 28px;
background:#00ff99;
color:#000;
font-weight:bold;
text-decoration:none;
border-radius:8px;
}

.section-title{
font-size:40px;
margin-bottom:10px;
}

.section-sub{
color:#888;
margin-bottom:40px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
}

.card{
background:#0f0f0f;
padding:30px;
border-radius:14px;
border:1px solid #1d1d1d;
}

.card h3{
font-size:30px;
margin-bottom:20px;
}

.card ul{
padding-left:18px;
}

.card li{
margin-bottom:12px;
color:#bbb;
}

.price{
font-size:56px;
font-weight:bold;
color:#00ff99;
margin:20px 0;
}

.images{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
margin-top:40px;
}

.images img{
width:100%;
height:260px;
object-fit:cover;
border-radius:12px;
border:1px solid #222;
}

.payment-box{
margin-top:25px;
background:#0f0f0f;
padding:25px;
border-radius:12px;
border:1px solid #222;
}

.payment-box li{
margin-bottom:10px;
color:#bbb;
}

form{
margin-top:35px;
display:flex;
flex-direction:column;
gap:18px;
}

input,textarea{
padding:16px;
background:#111;
border:1px solid #222;
color:#fff;
border-radius:8px;
font-size:16px;
}

textarea{
min-height:140px;
resize:vertical;
}

button{
padding:16px;
background:#00ff99;
border:none;
border-radius:8px;
font-size:18px;
font-weight:bold;
cursor:pointer;
}

footer{
padding:50px 0;
text-align:center;
color:#666;
}

.status{
margin-top:15px;
font-weight:bold;
}

@media(max-width:700px){

.hero h1{
font-size:36px;
}

.section-title{
font-size:32px;
}

.card h3{
font-size:24px;
}

.price{
font-size:42px;
}

}
</style>
</head>

<body>

<section class="hero">
<div class="container">

<h1>VWELDCORE SYSTEMS</h1>

<p>
Industrial infrastructure, cold room systems, automation deployment,
operational tooling, and remote technical setup services for local and international clients.
</p>

<a class="telegram-btn" href="https://t.me/Vweldocore" target="_blank">
Contact on Telegram
</a>

</div>
</section>

<section>
<div class="container">

<h2 class="section-title">Operational Services</h2>

<p class="section-sub">
Infrastructure deployment, fabrication systems, and operational tooling.
</p>

<div class="grid">

<div class="card">
<h3>Industrial Infrastructure</h3>
<ul>
<li>Cold room installation</li>
<li>Stainless steel fabrication</li>
<li>Industrial welding systems</li>
<li>Shelving and rack fabrication</li>
<li>Commercial steel structures</li>
</ul>
</div>

<div class="card">
<h3>Automation Systems</h3>
<ul>
<li>Termux automation setup</li>
<li>Workflow deployment</li>
<li>Webhook integrations</li>
<li>Operational scripting</li>
<li>GitHub deployment systems</li>
<li>Infrastructure tooling</li>
</ul>
</div>

<div class="card">
<h3>Remote Technical Services</h3>
<ul>
<li>International remote setup</li>
<li>Infrastructure deployment</li>
<li>Technical operational support</li>
<li>Deployment assistance</li>
<li>System optimization</li>
</ul>
</div>

</div>

</div>
</section>

<section>
<div class="container">

<h2 class="section-title">Operational Projects</h2>

<div class="images">
<img src="images/coldroom.jpg" alt="Cold Room Project">
<img src="images/fabrication.jpg" alt="Fabrication Project">
<img src="images/runtime.jpg" alt="Runtime Infrastructure">
<img src="images/github.jpg" alt="Deployment Infrastructure">
</div>

</div>
</section>

<section>
<div class="container">

<h2 class="section-title">Starter Infrastructure Setup</h2>

<div class="card">

<div class="price">$49 USD</div>

<ul>
<li>Lightweight deployment environments</li>
<li>Operational tooling systems</li>
<li>Remote setup assistance</li>
<li>Workflow deployment support</li>
<li>Infrastructure configuration</li>
</ul>

</div>

<div class="payment-box">

<h3 style="margin-bottom:20px;">International Payments Accepted</h3>

<ul>
<li>USD Bank Transfer</li>
<li>USDT (TRC20)</li>
<li>Worldwide Remote Delivery</li>
<li>Crypto Payments Supported</li>
<li>Direct Telegram Coordination</li>
</ul>

</div>

</div>
</section>

<section>
<div class="container">

<h2 class="section-title">Request Setup</h2>

<form id="leadForm">

<input type="text" id="name" placeholder="Your Name" required>

<input type="email" id="email" placeholder="Your Email" required>

<input type="text" id="service" placeholder="Service Needed" required>

<textarea id="message" placeholder="Describe your request"></textarea>

<button type="submit">Submit Request</button>

<div class="status" id="status"></div>

</form>

</div>
</section>

<footer>
VWELDCORE SYSTEMS © 2026
</footer>

<script>
document.getElementById("leadForm").addEventListener("submit", function(e){

e.preventDefault();

const name = document.getElementById("name").value;
const email = document.getElementById("email").value;
const service = document.getElementById("service").value;
const message = document.getElementById("message").value;

const text =
"NEW VWELDCORE LEAD%0A%0A" +
"Name: " + name + "%0A" +
"Email: " + email + "%0A" +
"Service: " + service + "%0A%0A" +
"Request:%0A" + message;

window.open(
"https://t.me/Vweldocore?text=" + text,
"_blank"
);

document.getElementById("status").innerHTML =
"Lead redirected successfully to Telegram.";

});
</script>


</body>
</html>
